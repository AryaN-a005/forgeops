generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}
// ============================================================================
// 1. User - Managed by Clerk
// ============================================================================
model User {
  id       String  @id @default(cuid())
  clerkId  String  @unique
  email    String  @unique
  name     String?
  imageUrl String?

  // Relations
  memberships     Membership[]
  createdProjects Project[]
  deployments     Deployment[]
  secrets         Secret[]
  auditLogs       AuditLog[]
  notifications   Notification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clerkId])
}

// ============================================================================
// 2. Organization - Like GitHub organizations
// ============================================================================
model Organization {
  id   String @id @default(cuid())
  name String
  slug String @unique

  // Relations
  memberships Membership[]
  projects    Project[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
}

// ============================================================================
// 3. Membership - RBAC (Owner, Admin, Developer, Viewer)
// ============================================================================
model Membership {
  id             String @id @default(cuid())
  userId         String
  organizationId String
  role           Role   @default(DEVELOPER)

  // Relations
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, organizationId])
  @@index([userId])
  @@index([organizationId])
}

enum Role {
  OWNER
  ADMIN
  DEVELOPER
  VIEWER
}

// ============================================================================
// 4. Project - Core entity
// ============================================================================
model Project {
  id             String  @id @default(cuid())
  name           String
  description    String?
  organizationId String
  createdById    String?

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User?        @relation(fields: [createdById], references: [id], onDelete: SetNull)

  repository   Repository?
  environments Environment[]
  deployments  Deployment[]
  builds       Build[]
  pipelines    Pipeline[]
  secrets      Secret[]
  variables    Variable[]
  webhooks     Webhook[]
  namespaces   Namespace[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([createdById])
}

// ============================================================================
// 5. Repository - Connected Git repository
// ============================================================================
model Repository {
  id            String      @id @default(cuid())
  projectId     String      @unique
  provider      GitProvider
  repoUrl       String
  repoName      String
  defaultBranch String      @default("main")

  // Relations
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
}

enum GitProvider {
  GITHUB
  GITLAB
  BITBUCKET
}

// ============================================================================
// 6. Environment - Deployment environments
// ============================================================================
model Environment {
  id        String          @id @default(cuid())
  projectId String
  name      String
  type      EnvironmentType

  // Relations
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  deployments Deployment[]
  secrets     Secret[]
  variables   Variable[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, name])
  @@index([projectId])
}

enum EnvironmentType {
  DEVELOPMENT
  STAGING
  PRODUCTION
}

// ============================================================================
// 7. Cluster - Kubernetes cluster
// ============================================================================
model Cluster {
  id         String          @id @default(cuid())
  name       String
  provider   ClusterProvider
  region     String
  kubeConfig String // JSON stored as string

  // Relations
  namespaces  Namespace[]
  deployments Deployment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([provider])
}

enum ClusterProvider {
  EKS
  GKE
  AKS
  KIND
  MINIKUBE
}

// ============================================================================
// 8. Namespace - Namespace inside cluster
// ============================================================================
model Namespace {
  id        String @id @default(cuid())
  clusterId String
  projectId String
  name      String

  // Relations
  cluster     Cluster      @relation(fields: [clusterId], references: [id], onDelete: Cascade)
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  deployments Deployment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clusterId, projectId, name])
  @@index([clusterId])
  @@index([projectId])
}

// ============================================================================
// 9. Deployment - Deployment history
// ============================================================================
model Deployment {
  id            String           @id @default(cuid())
  projectId     String
  environmentId String
  clusterId     String?
  namespaceId   String?
  imageTag      String
  commitSha     String
  status        DeploymentStatus @default(PENDING)
  deployedById  String?

  // Relations
  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  environment Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  cluster     Cluster?    @relation(fields: [clusterId], references: [id], onDelete: SetNull)
  namespace   Namespace?  @relation(fields: [namespaceId], references: [id], onDelete: SetNull)
  deployedBy  User?       @relation(fields: [deployedById], references: [id], onDelete: SetNull)

  metrics Metric[]
  logs    Log[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([environmentId])
  @@index([clusterId])
  @@index([status])
}

enum DeploymentStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
  ROLLBACK
}

// ============================================================================
// 10. Build - CI build record
// ============================================================================
model Build {
  id        String      @id @default(cuid())
  projectId String
  commitSha String
  branch    String
  status    BuildStatus @default(PENDING)
  duration  Int? // in seconds
  logsUrl   String?

  // Relations
  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  pipelines Pipeline[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([commitSha])
  @@index([status])
}

enum BuildStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
}

// ============================================================================
// 11. Pipeline - Pipeline execution
// ============================================================================
model Pipeline {
  id        String           @id @default(cuid())
  projectId String
  buildId   String
  provider  PipelineProvider
  status    PipelineStatus   @default(PENDING)

  // Relations
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  build   Build   @relation(fields: [buildId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([buildId])
}

enum PipelineProvider {
  GITHUB_ACTIONS
  GITLAB_CI
  JENKINS
}

enum PipelineStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
}

// ============================================================================
// 12. Secret - Kubernetes secrets (encrypted)
// ============================================================================
model Secret {
  id             String  @id @default(cuid())
  projectId      String
  environmentId  String
  key            String
  valueEncrypted String
  createdById    String?

  // Relations
  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  environment Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  createdBy   User?       @relation(fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, environmentId, key])
  @@index([projectId])
  @@index([environmentId])
}

// ============================================================================
// 13. Variable - Non-sensitive env vars
// ============================================================================
model Variable {
  id            String @id @default(cuid())
  projectId     String
  environmentId String
  key           String
  value         String

  // Relations
  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  environment Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, environmentId, key])
  @@index([projectId])
  @@index([environmentId])
}

// ============================================================================
// 14. Webhook - Git provider webhooks
// ============================================================================
model Webhook {
  id        String      @id @default(cuid())
  projectId String
  provider  GitProvider
  secret    String
  endpoint  String

  // Relations
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
}

// ============================================================================
// 15. AuditLog - Important for tracking
// ============================================================================
model AuditLog {
  id         String  @id @default(cuid())
  userId     String
  action     String
  resource   String
  resourceId String
  details    String? // JSON as string

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  timestamp DateTime @default(now())

  @@index([userId])
  @@index([resource])
  @@index([timestamp])
}

// ============================================================================
// 16. Notification - Future feature
// ============================================================================
model Notification {
  id      String           @id @default(cuid())
  userId  String
  title   String
  message String
  type    NotificationType
  read    Boolean          @default(false)

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())
  readAt    DateTime?

  @@index([userId])
  @@index([read])
}

enum NotificationType {
  DEPLOYMENT
  BUILD
  ERROR
}

// ============================================================================
// 17. Metric - Monitoring
// ============================================================================
model Metric {
  id           String @id @default(cuid())
  deploymentId String
  cpuUsage     Float
  memoryUsage  Float
  networkUsage Float

  // Relations
  deployment Deployment @relation(fields: [deploymentId], references: [id], onDelete: Cascade)

  timestamp DateTime @default(now())

  @@index([deploymentId])
  @@index([timestamp])
}

// ============================================================================
// 18. Log - Application logs
// ============================================================================
model Log {
  id           String   @id @default(cuid())
  deploymentId String
  level        LogLevel
  message      String

  // Relations
  deployment Deployment @relation(fields: [deploymentId], references: [id], onDelete: Cascade)

  timestamp DateTime @default(now())

  @@index([deploymentId])
  @@index([timestamp])
  @@index([level])
}

enum LogLevel {
  DEBUG
  INFO
  WARN
  ERROR
}
